{
  "cSpell.customDictionaries": {
    "custom-dictionary-workspace": {
      "name": "custom-dictionary-workspace",
      "path": "${workspaceFolder:acmetas}/.cspell/custom-dictionary-workspace.txt",
      "addWords": true,
      "scope": "workspace"
    }
  },
  "emeraldwalk.runonsave": {
    "message": "running...",
    "commands": [
      {
        "message": "{relativeFile}",
        "match": "src\\\\.*\\.(af|met|nav)$",
        "cmd": "powershell -NoProfile -Command \"$rel='${relativeFile}'; $rel=$rel -replace '^src\\\\',''; $reldir=Split-Path $rel -Parent; metaf ${file} dist\\\\${reldir}\\\\"
      }
    ]
  }
}