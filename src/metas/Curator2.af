~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~ The Meta Process Goes Here
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
~~ Uses portal gem to go to TN. Retries every 2 seconds.
STATE: {GoToEncampment} ~~ {
	IF: Always
		DO: EmbedNav nav_empty {[None]}
	IF: All
			Not Expr {isportaling[]}
			Expr {getbusystate[]==0}
		DO: DoExpr {chatbox[\/ub usei Rynthid Encampment Recall Gem +\(+getvar[realm]+\)]}
	IF: All
			ExitPortal
			BlockE 30320000
		DO: Return
	IF: All
			Not Expr {isportaling[]}
			SecsInStateGE 5
		DO: SetState {GoToEncampment}
~~ }

STATE: {0-init} ~~ {
	IF:	Always
		DO:	DoAll
				SetOpt {EnableNav} {true}
				SetOpt {EnableLooting} {false}
				SetOpt {EnableCombat} {false}
				CallState {GoToEncampment} {1-Load-Curator-Nav}
~~ }

STATE: {1-Load-Curator-Nav} ~~ {
	IF: Always
		DO: DoAll
				EmbedNav nav_to_curator {RunToCurator}
				SetState {2-Run}
~~ }
STATE: {2-Run} ~~ {
	IF:	ChatCapture {cast (.*) on you(\.|,|\s|$)} {}
		DO:	DoAll
				Chat {/ub useip Eternal Gem of Dispelling}
				SetState {2-Run}
	IF: All
			SecsInStateGE 10
			NavEmpty
			Not Expr {wobjectfindnearestbynameandobjectclass[27,Corpse of Curator of Torment]!=0}
			Not Expr {wobjectfindnearestbynameandobjectclass[5,Curator of Torment]!=0}
		DO: SetState {IncDiff}
	IF:	All
			NavEmpty
			Expr {wobjectfindnearestbynameandobjectclass[27,Corpse of Curator of Torment]!=0}
		DO:	SetState {3-Loot}
	IF:	Death
		DO:	CallState {Death} {1-RE}
~~ }
STATE: {3-Loot} ~~ {
~~ If we have already looted AND the corpse is still open, close it.
	IF: All
			Expr {wobjectfindininventorybynamerx[Shard of the Curator]!=0}
			Expr {wobjectgetopencontainer[]!=0}
		DO: DoExpr {actiontryuseitem[wobjectgetopencontainer[]]}
	
~~ If we've looted AND closed the container, start turn in.
	IF:	All
			Expr {wobjectgetopencontainer[]==0}
			Expr {wobjectfindininventorybynamerx[Shard of the Curator]!=0}
			Expr {getbusystate[]==0}
		DO:	CallState {GoToEncampment} {4-Load-Turnin-Nav}
			
~~ If no mobs nearby, and a container isn't open, open the corpse.
	IF:	All
			NoMobsInDist 10
			Expr {wobjectgetopencontainer[]==0}
			Not Expr {wobjectfindininventorybynamerx[Shard of the Curator]!=0} 
		DO:	Chat {/ub uselp Corpse of Curator of Torment}
		
~~ If the currently open corpse has the shard, loot it
	IF:	All
			Expr {wobjectgetopencontainer[]!=0}
			Expr {listcount[listfilter[wobjectfindallbycontainer[wobjectgetopencontainer[]],`strlen[wobjectgetname[$1]]>25&&wobjectgetname[$1]{{-25:}}==Curator of Torment's Mask`]]>0}
		DO:	Chat {/mt lootp Shard of the Curator}

	IF:	SecsInStateGE 3
		DO:	SetState {3-Loot}

	IF:	All
			Death
			Expr {wobjectfindininventorybynamerx[Shard of the Curator]!=0}
		DO:	SetState {3-Loot}

	IF:	All
			Death
			Not Expr {wobjectfindininventorybynamerx[Shard of the Curator]!=0}
		DO:	CallState {Death} {1-RE}
~~ }
STATE: {4-Load-Turnin-Nav} ~~ {
	IF: Always
		DO: DoAll
				EmbedNav nav_turnin { TurnIn.nav}
				SetState {5-TurnIn}
~~ }
STATE: {5-TurnIn} ~~ {
	IF:	Always
		DO:	Chat {/b d}

	IF: All
			NavEmpty
			Expr {wobjectfindininventorybynamerx[Shard of the Curator]!=0}
		DO: Chat {/mt givep Shard of the Curator to Morgethais}

	IF:	Not Expr {wobjectfindininventorybynamerx[Shard of the Curator]!=0}
		DO:	SetState {IncDiff}
	
	IF: All
			NavEmpty
			SecsInStateGE 5
			Expr {wobjectfindininventorybynamerx[Shard of the Curator]!=0}
		DO: SetState {5-TurnIn}
~~ }

